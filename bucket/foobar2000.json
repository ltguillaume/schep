{
    "version": "2.25.9",
    "description": "An advanced freeware audio player for the Windows platform. Uses junction in AppData instead of portable mode, so file associations work.",
    "homepage": "https://www.foobar2000.org/",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.foobar2000.org/license"
    },
    "suggest": {
        "Encoders": "extras/foobar2000-encoders"
    },
    "notes": [
        "For file associations, if you see \"Class not registered\", run the following as Administrator:",
        "regsvr32 \"$dir\\Fb2kShellExt.dll\""
    ],
    "architecture": {
        "64bit": {
            "url": "https://www.foobar2000.org/files/foobar2000-x64_v2.25.9.exe#/dl.7z",
            "hash": "70d365a747bda8c3b7309ff7bb91a93f40bab0c19763c8d869031154b37e281b"
        },
        "32bit": {
            "url": "https://www.foobar2000.org/files/foobar2000_v2.25.9.exe#/dl.7z",
            "hash": "28a69ee37c25a3366c5ef5fe499e44a3f02954facf0fec151157a6e3f3cd4746"
        },
        "arm64": {
            "url": "https://www.foobar2000.org/files/foobar2000-arm64ec_v2.25.9.exe#/dl.7z",
            "hash": "dececbd32ac1169d25c6fc8920670473d602e24d5fcd578ae75754a214eb4270"
        }
    },
    "installer": {
        "script": [
            "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse",
            "Rename-Item \"$dir\\`$R0\" \"Fb2kShellExt.dll\"",
            "$EncodersDir = $(appdir foobar2000-encoders $global)",
            "if (Test-Path \"$EncodersDir\") {",
            "    New-Item \"$dir\\encoders\" -ItemType Junction -Target \"$EncodersDir\\current\" | Out-Null",
            "}"
        ]
    },
    "post_install": [
        "if (-not (Test-Path \"$Env:AppData\\foobar2000-v2\\*\")) {",
        "    Remove-Item \"$Env:AppData\\foobar2000-v2\" 2>$null",
        "    if (-not (Test-Path \"$persist_dir\")) {",
        "        New-Item -ItemType Directory -Path \"$persist_dir\" >$null",
        "    }",
        "    New-DirectoryJunction \"$Env:AppData\\foobar2000-v2\" \"$persist_dir\" >$null",
        "}"
    ],
    "pre_uninstall": [
        "$fb2k_data = Get-Item \"$Env:AppData\\foobar2000-v2\"",
        "if (\"$($fb2k_data.Target)\" -eq \"$persist_dir\") { $fb2k_data.Delete() }"
    ],
    "bin": "foobar2000.exe",
    "shortcuts": [
        [
            "foobar2000.exe",
            "Foobar2000"
        ]
    ],
    "checkver": {
        "url": "https://www.foobar2000.org/download",
        "regex": "foobar2000_v([\\d.]+)\\."
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.foobar2000.org/files/foobar2000-x64_v$version.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://www.foobar2000.org/files/foobar2000_v$version.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://www.foobar2000.org/files/foobar2000-arm64ec_v$version.exe#/dl.7z"
            }
        }
    }
}
