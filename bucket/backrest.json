{
    "version": "1.12.1",
    "description": "Web UI and orchestrator for restic backup. Portable version with Start Menu shortcut to Backrest Tray.",
    "homepage": "https://github.com/garethgeorge/backrest",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/garethgeorge/backrest/releases/download/v1.12.1/backrest_Windows_x86_64.zip",
            "hash": "b0158390f7e54742c380d27d515d05db5a0dbb5d45bc4101af7b27989cac35c0"
        },
        "arm64": {
            "url": "https://github.com/garethgeorge/backrest/releases/download/v1.12.1/backrest_Windows_arm64.zip",
            "hash": "e8574c13121d609c152dbb802ea2b3204bd6f1d8b7ecec09c00b58f43e46edd9"
        }
    },
    "bin": "backrest.exe",
    "shortcuts": [
        [
            "backrest.exe",
            "Backrest"
        ]
    ],
    "post_install": [
        "if (-not (Test-Path \"$Env:AppData\\backrest\\*\")) {",
        "    Remove-Item \"$Env:AppData\\backrest\" 2>$null",
        "}",
        "if (-not (Test-Path \"$persist_dir\\data\")) {",
        "    New-Item -ItemType \"directory\" -Path \"$persist_dir\\data\" >$null",
        "}",
        "$current_config = Get-EnvVar -Name BACKREST_CONFIG -Global:$global",
        "If ($null -eq $current_config) {",
        "    $path = \"$persist_dir\\config.json\"",
        "    Set-EnvVar -Name BACKREST_CONFIG -Value $path -Global:$global",
        "    $Env:BACKREST_CONFIG = $path",
        "    Write-Host \"Environment variable 'BACKREST_CONFIG' set to '$path'\"",
        "}",
        "$current_data = Get-EnvVar -Name BACKREST_DATA -Global:$global",
        "If ($null -eq $current_data) {",
        "    $path = \"$persist_dir\\data\"",
        "    Set-EnvVar -Name BACKREST_DATA -Value $path -Global:$global",
        "    $Env:BACKREST_DATA = $path",
        "    Write-Host \"Environment variable 'BACKREST_DATA' set to '$path'\"",
        "}"
    ],
    "pre_uninstall": [
        "$path = \"$persist_dir\\config.json\"",
        "$current_config = Get-EnvVar -Name BACKREST_CONFIG -Global:$global",
        "If ($path -eq $current_config) {",
        "    Set-EnvVar -Name BACKREST_CONFIG -Value \"\" -Global:$global",
        "}",
        "$path = \"$persist_dir\\data\"",
        "$current_data = Get-EnvVar -Name BACKREST_DATA -Global:$global",
        "If ($path -eq $current_data) {",
        "    Set-EnvVar -Name BACKREST_DATA -Value \"\" -Global:$global",
        "}",
        "$backrest_data = Get-Item \"$Env:AppData\\backrest\" 2>$null",
        "if (\"$($backrest_data.Target)\" -eq \"$persist_dir\") { $backrest_data.Delete() }"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/garethgeorge/backrest/releases/download/v$version/backrest_Windows_x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/garethgeorge/backrest/releases/download/v$version/backrest_Windows_arm64.zip"
            }
        },
        "hash": {
            "url": "$baseurl/backrest_$version_checksums.txt",
            "regex": "$sha256\\s+$basename"
        }
    }
}
