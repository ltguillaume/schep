{
    "##": "ltguillaume/schep",
    "version": "140.10.2",
    "description": "Extended Support Release of Firefox: the popular open source web browser. This variant makes sure the Scoop-ESR profile is used.",
    "homepage": "https://www.mozilla.org/en-US/firefox/organizations/",
    "license": "MPL-2.0",
    "notes": "After installation, the profile manager will be run to choose the right default profile.",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/140.10.2esr/win64/en-US/Firefox%20Setup%20140.10.2esr.exe#/dl.7z",
            "hash": "sha512:f6bcb4315d956c51927163db967763ce2c7819c9b62efbaaf2842ce31b37b41667e7ccfcfba14e94c308b969daa0fcf52fe3d4652de419883f48c4a03122cd7a"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/140.10.2esr/win32/en-US/Firefox%20Setup%20140.10.2esr.exe#/dl.7z",
            "hash": "sha512:d41c7bd9b2a22016df15a2e6d24e07f2635a9022837a159ddc7208be61947bbf198e26663b123dc371d80d240a76a9a643dc7fcc8d40cfd4d3ea6529bd2d6739"
        },
        "arm64": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/140.10.2esr/win64-aarch64/en-US/Firefox%20Setup%20140.10.2esr.exe#/dl.7z",
            "hash": "sha512:b2bbc5dc7b29f326a24f5e2afcca142df4fbd889e6e4ea5e943a69beae2c1dd2533e4a04c9fb9ad8ffe4a0a746a6674367a32059fc0411c302e9cb3b40efa993"
        }
    },
    "extract_dir": "core",
    "post_install": [
        "$Addition = \"$persist_dir\\addition\"",
        "if (Test-Path $Addition) {",
        "  info 'Copying additional items...'",
        "  Copy-Item -Path $Addition\\* -Destination $dir -Force -Recurse -ErrorAction SilentlyContinue",
        "}",
        "if (!(Test-Path \"$persist_dir\\profile\\times.json\")) {",
        "    firefox-esr.exe -CreateProfile \"Scoop-ESR $persist_dir\\profile\"",
        "}",
        "Start-Process -WorkingDirectory $dir -FilePath firefox.exe -ArgumentList '-P'"
    ],
    "bin": [
        [
            "firefox.exe",
            "firefox-esr"
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox ESR"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "checkver": {
        "url": "https://aus5.mozilla.org/update/6/Firefox/115.0/_/WINNT_x86_64-msvc-x64/en-US/esr/_/_/_/_/update.xml",
        "xpath": "/updates/update/@appVersion"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$versionesr/win64/en-US/Firefox%20Setup%20$versionesr.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$versionesr/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$versionesr/win32/en-US/Firefox%20Setup%20$versionesr.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$versionesr/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            },
            "arm64": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$versionesr/win64-aarch64/en-US/Firefox%20Setup%20$versionesr.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$versionesr/SHA512SUMS",
                    "regex": "$sha512\\s+win64-aarch64/en-US/$basename"
                }
            }
        }
    }
}
